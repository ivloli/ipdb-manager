# Latest config template (compatible design)
# Note: keep legacy blocks for backward compatibility.

# -------------------------
# Legacy fields (existing code relies on them)
# -------------------------
nacos:
  addr: "139.159.195.20:8848"
  namespace: "scloud-prod"
  group: "subnet_mapping"
  data_id: "subnet_map"
  data_id_v6: "subnet_map_v6"
  username: "${NACOS_USERNAME}"
  password: "${NACOS_PASSWORD}"

ip2region:
  dir: "/var/lib/ipdb-manager/ip2region"
  txt_path: "/var/lib/ipdb-manager/ip2region/ipv4_source.txt"
  xdb_path: "/var/lib/ipdb-manager/ip2region/ip2region_v4.xdb"
  txt_v6_path: "/var/lib/ipdb-manager/ip2region/ipv6_source.txt"
  xdb_v6_path: "/var/lib/ipdb-manager/ip2region/ip2region_v6.xdb"
  poll_interval: "24h" # 仅兼容模式使用；新模式由 scheduler.cron 驱动
  github_token: "${GITHUB_TOKEN}"
  releases_url: "https://api.github.com/repos/lionsoul2014/ip2region/releases/latest"

api:
  listen: ":9090"
  token: "${IPDB_MANAGER_API_TOKEN}"

# -------------------------
# New fields (multi nacos + multi artifact)
# -------------------------
scheduler:
  cron: "0 2 * * *" # 新模式自动触发（建议用 robfig/cron/v3）

local_state:
  upstream_release_tag_file: "/var/lib/ipdb-manager/ip2region/.upstream_release_tag"
  # auto-migrate from legacy .version file when present
  legacy_version_file: "/var/lib/ipdb-manager/ip2region/.version"

versioning:
  format: "vYYYY.MM.DD.N"
  source_of_truth:
    type: nacos
    nacos_id: nacos_cn_prod
    group: ip_data_v4
    data_id: ip2region_meta

artifact_repos:
  - id: jfrog_cn
    type: jfrog
    base_url: https://jfrog-cn.example.com
    repo: ipdb-local
    enabled: true
    auth:
      token_ref: JFROG_CN_TOKEN
      # username_ref: JFROG_CN_USER
      # password_ref: JFROG_CN_PASS

  - id: jfrog_sg
    type: jfrog
    base_url: https://jfrog-sg.example.com
    repo: ipdb-local
    enabled: true
    auth:
      token_ref: JFROG_SG_TOKEN

  - id: nexus_cn
    type: nexus
    # Example Nexus base URL can be either server root or /repository root.
    # root: https://nexus-cn.example.com
    # repository root: https://nexus-cn.example.com/repository
    base_url: https://nexus-cn.example.com
    repo: ipdb-raw-hosted
    enabled: false
    auth:
      username_ref: NEXUS_CN_USER
      password_ref: NEXUS_CN_PASS

nacos_targets:
  - id: nacos_cn_prod
    server_addr: nacos-cn.example.com:8848
    namespace: scloud-prod
    enabled: true
    auth:
      username_ref: NACOS_CN_USER
      password_ref: NACOS_CN_PASS
    artifact_repo_id: jfrog_cn
    artifact_path_templates:
      v4: "ip2region/{{version}}/ip2region_v4.xdb"
      v6: "ip2region/{{version}}/ip2region_v6.xdb"
    publish:
      v4:
        group: ip_data_v4
        data_id: ip2region_meta
      v6:
        group: ip_data_v6
        data_id: ip2region_meta

  - id: nacos_sg_prod
    server_addr: nacos-sg.example.com:8848
    namespace: scloud-prod
    enabled: true
    auth:
      username_ref: NACOS_SG_USER
      password_ref: NACOS_SG_PASS
    artifact_repo_id: jfrog_sg
    artifact_path_templates:
      v4: "ip2region/{{version}}/ip2region_v4.xdb"
      v6: "ip2region/{{version}}/ip2region_v6.xdb"
    publish:
      v4:
        group: ip_data_v4
        data_id: ip2region_meta
      v6:
        group: ip_data_v6
        data_id: ip2region_meta

xdb_reconcile:
  fail_fast: false
  max_parallel_targets: 4
  retry:
    max_attempts: 3
    backoff_seconds: 5

consistency:
  # Ensure subnet-map update and xdb publish use the same snapshot.
  enforce_snapshot_consistency: true
  # If xdb reconcile not converged, do not publish subnet-map in this round.
  block_subnet_publish_on_xdb_mismatch: true

http_api:
  reconcile:
    enabled: true
    path: /api/v1/reconcile
    # default async mode to avoid timeout
    async: true
