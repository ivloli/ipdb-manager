pipeline {
  agent any

  options {
    buildDiscarder(logRotator(numToKeepStr: '15'))
    disableConcurrentBuilds()
    timestamps()
  }

  parameters {
    choice(name: 'ACTION', choices: ['Release', 'Rollback'], description: 'Deploy mode： Release 发版，Rollback 回滚')

    gitParameter(
      name: 'GIT_REF',
      type: 'PT_BRANCH_TAG',
      defaultValue: 'main',
      branchFilter: 'origin/(.*)',
      sortMode: 'DESCENDING_SMART',
      selectedValue: 'TOP',
      useRepository: 'git@gitlab.gainetics.io:backend-cdn/dns-prj/ipdb_manager.git',
      quickFilterEnabled: true
    )

    text(
      name: 'CONFIG_YAML',
      defaultValue: '',
      description: '仅 Release 使用：会写入离线包里的 config.yaml'
    )

    string(
      name: 'ROLLBACK_ARTIFACT',
      defaultValue: '',
      description: '仅 Rollback 使用，例如 ipdb-manager-offline-linux-amd64-xxxx.tar.gz'
    )

    extendedChoice(
      name: 'TARGET_IP',
      description: '选择部署的节点IP（当前只有一台）',
      type: 'PT_MULTI_SELECT',
      value: '10.0.5.238',
      defaultValue: '10.0.5.238',
      multiSelectDelimiter: ',',
      visibleItemCount: 5
    )

    string(name: 'TARGET_PORT', defaultValue: '22', description: 'Remote SSH port')
    string(name: 'TARGET_USER', defaultValue: 'root', description: 'Remote SSH user')
    string(name: 'TARGET_DIR', defaultValue: '/opt/ipdb-manager/releases', description: 'Remote deploy directory')
    string(name: 'REMOTE_SERVICE', defaultValue: 'ipdb-manager', description: 'Systemd service name')
    booleanParam(name: 'USE_SUDO', defaultValue: true, description: 'Use sudo for remote install and restart')

    string(name: 'TARGET_OS', defaultValue: 'linux', description: 'Target OS for release package')
    string(name: 'TARGET_ARCH', defaultValue: 'amd64', description: 'Target architecture for release package')
    string(name: 'RELEASE_TAG', defaultValue: '', description: 'Optional release tag (empty = Makefile default)')
  }

  environment {
    APP_NAME = "ipdb-manager"

    GIT_CREDENTIALS_ID = 'deploy'
    REPOSITORY_URL     = 'git@gitlab.gainetics.io:backend-cdn/dns-prj/ipdb_manager.git'

    PATH = "/usr/local/go/bin:${env.PATH}"

    SSH_CRED_ID = 'ipdb-manager-ssh'

    JFROG_REPO_URL = 'https://artifactory.gainetics.io/artifactory/observe-dnps/prod-ipdb-xdb-manager'
    JFROG_USER     = 'dnps'
    JFROG_PASS     = 'SXKvkwRICe743VPhTkKIbA=='
  }

  stages {
    stage('Validate Parameters') {
      steps {
        script {
          def action = (params.ACTION ?: '').trim()
          if (!(action in ['Release', 'Rollback'])) {
            error('ACTION must be Release or Rollback')
          }

          if (action == 'Release') {
            def ref = (params.GIT_REF ?: '').trim()
            if (!ref) {
              error('GIT_REF is empty in Release mode')
            }

            def cfg = (params.CONFIG_YAML ?: '').trim()
            if (!cfg) {
              error('CONFIG_YAML is empty in Release mode')
            }

            echo 'Mode: Release'
            echo "GIT_REF: ${ref}"
          }

          if (action == 'Rollback') {
            def artifact = (params.ROLLBACK_ARTIFACT ?: '').trim()
            if (!artifact || artifact in ['NO_ARTIFACT_FOUND', 'ERROR', 'ERROR_FETCHING_ARTIFACTS']) {
              error("ROLLBACK_ARTIFACT is invalid in Rollback mode: ${artifact}")
            }

            def appNamePattern = java.util.regex.Pattern.quote(env.APP_NAME)
            def artifactPattern = ~/^${appNamePattern}-offline-linux-amd64-.+\.tar\.gz$/
            if (!(artifact ==~ artifactPattern)) {
              error("ROLLBACK_ARTIFACT format invalid: ${artifact}")
            }

            echo 'Mode: Rollback'
            echo "ROLLBACK_ARTIFACT: ${artifact}"
          }

          def targetIps = (params.TARGET_IP ?: '').trim()
          if (!targetIps) {
            error('TARGET_IP 不能为空，请选择至少一个部署节点IP')
          }
        }
      }
    }

    stage('Clean Workspace') {
      steps {
        deleteDir()
      }
    }

    stage('Checkout & Submodules') {
      steps {
        script {
          def ref = (params.GIT_REF ?: 'main').toString().trim()
          if (!ref) {
            error('GIT_REF is empty')
          }

          def repoUrl = env.REPOSITORY_URL?.trim()
          def credId = env.GIT_CREDENTIALS_ID?.trim()

          if (!repoUrl) {
            error('REPOSITORY_URL is empty')
          }
          if (!credId) {
            error('GIT_CREDENTIALS_ID is empty')
          }

          echo "GIT_REF=${ref}"
          echo "REPOSITORY_URL=${repoUrl}"
          echo "GIT_CREDENTIALS_ID=${credId}"

          def isTag = false
          def isBranch = false

          withCredentials([sshUserPrivateKey(
            credentialsId: credId,
            keyFileVariable: 'GIT_SSH_KEY',
            usernameVariable: 'GIT_SSH_USER'
          )]) {
            isTag = (sh(
              script: """#!/usr/bin/env bash
set +e
export GIT_SSH_COMMAND=\"ssh -i '$GIT_SSH_KEY' -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null\"
git ls-remote --tags '${repoUrl}' 'refs/tags/${ref}' | grep -q .
""",
              returnStatus: true
            ) == 0)

            isBranch = (sh(
              script: """#!/usr/bin/env bash
set +e
export GIT_SSH_COMMAND=\"ssh -i '$GIT_SSH_KEY' -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null\"
git ls-remote --heads '${repoUrl}' 'refs/heads/${ref}' | grep -q .
""",
              returnStatus: true
            ) == 0)
          }

          if (!isTag && !isBranch) {
            error("GIT_REF not found in remote as either tag or branch: ${ref}")
          }

          if (isTag && isBranch) {
            echo "Warning: ref '${ref}' exists as both tag and branch, tag will be used first."
          }

          def refName = isTag ? "refs/tags/${ref}" : "refs/heads/${ref}"

          echo "Detected TAG   : ${isTag}"
          echo "Detected BRANCH: ${isBranch}"
          echo "Checkout ref   : ${refName}"

          checkout([
            $class: 'GitSCM',
            branches: [[name: refName]],
            userRemoteConfigs: [[
              url: repoUrl,
              credentialsId: credId,
              refspec: '+refs/heads/*:refs/remotes/origin/* +refs/tags/*:refs/tags/*'
            ]],
            extensions: [
              [$class: 'CloneOption', shallow: false, noTags: false, timeout: 20],
              [$class: 'CleanBeforeCheckout']
            ]
          ])

          sh '''#!/usr/bin/env bash
set -euo pipefail
echo "==> Current HEAD"
git rev-parse --short HEAD
git log -1 --oneline

echo "==> Sync submodules"
git submodule sync --recursive
git submodule update --init --recursive

echo "==> Final HEAD"
git show -s --oneline HEAD
'''

          echo "Checked out ref: ${refName}"
        }
      }
    }

    stage('Inject Config From Jenkins') {
      when {
        expression { params.ACTION == 'Release' }
      }
      steps {
        script {
          env.CONFIG_SRC = "${env.WORKSPACE}/jenkins-config.yaml"
          writeFile file: env.CONFIG_SRC, text: params.CONFIG_YAML
          sh "test -s '${env.CONFIG_SRC}'"
        }
      }
    }

    stage('Prepare Artifact') {
      when {
        expression { params.ACTION == 'Release' }
      }
      steps {
        script {
          env.GIT_COMMIT_SHORT = sh(script: 'git rev-parse --short=8 HEAD', returnStdout: true).trim()
          env.BUILD_TS = sh(script: 'date +%Y%m%d%H%M%S', returnStdout: true).trim()

          env.RELEASE_TAG_EFFECTIVE = (params.RELEASE_TAG ?: '').trim() ?: "${env.GIT_COMMIT_SHORT}-${env.BUILD_TS}"
          env.ARCHIVE_NAME = "${env.APP_NAME}-offline-${params.TARGET_OS}-${params.TARGET_ARCH}-${env.RELEASE_TAG_EFFECTIVE}.tar.gz"
          env.ARCHIVE_SRC = "${env.WORKSPACE}/${env.ARCHIVE_NAME}"
          env.ARTIFACT_NAME = env.ARCHIVE_NAME

          sh """
            set -euo pipefail
            make release-package \
              TARGET_OS='${params.TARGET_OS}' \
              TARGET_ARCH='${params.TARGET_ARCH}' \
              RELEASE_TAG='${env.RELEASE_TAG_EFFECTIVE}' \
              CONFIG_SRC='${env.CONFIG_SRC}'

            test -f '${env.ARCHIVE_SRC}'
            echo '=== release archive ==='
            ls -al '${env.ARCHIVE_SRC}'
            du -h '${env.ARCHIVE_SRC}'
            tar -tzf '${env.ARCHIVE_SRC}' | sed -n '1,20p'
          """

          echo "Prepared release archive: ${env.ARCHIVE_NAME}"
        }
      }
    }

    stage('Download Artifact') {
      when {
        expression { params.ACTION == 'Rollback' }
      }
      steps {
        script {
          env.ARTIFACT_NAME = (params.ROLLBACK_ARTIFACT ?: '').trim()
          env.ARCHIVE_NAME = env.ARTIFACT_NAME
          env.ARCHIVE_SRC = "${env.WORKSPACE}/${env.ARCHIVE_NAME}"

          sh """
            set -euo pipefail
            curl --fail --show-error --silent \
              -u "${env.JFROG_USER}:${env.JFROG_PASS}" \
              -o "${env.ARCHIVE_SRC}" \
              "${env.JFROG_REPO_URL}/${env.ARCHIVE_NAME}"

            echo '=== downloaded archive ==='
            ls -al '${env.ARCHIVE_SRC}'
            du -h '${env.ARCHIVE_SRC}'
          """

          echo "Downloaded rollback archive: ${env.ARCHIVE_NAME}"
        }
      }
    }

    stage('Deploy To Targets') {
      steps {
        script {
          def deploySrc = (env.ARCHIVE_SRC ?: '').trim()
          if (!deploySrc) {
            error('ARCHIVE_SRC is empty')
          }

          sh """
            set -e
            test -f "${deploySrc}"
            ls -al "${deploySrc}"
          """

          def hosts = (params.TARGET_IP ?: '').trim()
            .replace(',', ' ')
            .split(/\s+/)
            .findAll { it }

          if (hosts.isEmpty()) {
            error('TARGET_IP env is empty')
          }

          def deployUser = (params.TARGET_USER ?: 'root').trim()
          def deployPort = (params.TARGET_PORT ?: '22').trim()
          def deployDir = (params.TARGET_DIR ?: '/opt/ipdb-manager/releases').trim()
          def remoteService = (params.REMOTE_SERVICE ?: 'ipdb-manager').trim()

          echo "Deploy artifact : ${env.ARCHIVE_NAME}"
          echo "Source archive   : ${deploySrc}"
          echo "Deploy targets (${hosts.size()}): ${hosts.join(', ')}"
          echo "TARGET_USER=${deployUser}"
          echo "TARGET_PORT=${deployPort}"
          echo "TARGET_DIR=${deployDir}"
          echo "REMOTE_SERVICE=${remoteService}"

          withCredentials([sshUserPrivateKey(
            credentialsId: env.SSH_CRED_ID,
            keyFileVariable: 'SSH_KEY_FILE'
          )]) {
            def fanout = [:]

            for (int i = 0; i < hosts.size(); i++) {
              def host = hosts[i]

              fanout["deploy_${host}"] = {
                sh """#!/usr/bin/env bash
set -euo pipefail

echo '==> [${host}] ensure dir: ${deployDir}'
ssh -p "${deployPort}" \
  -i "\$SSH_KEY_FILE" \
  -o StrictHostKeyChecking=accept-new \
  -o ConnectTimeout=8 \
  -o ServerAliveInterval=10 \
  -o ServerAliveCountMax=2 \
  "${deployUser}@${host}" "mkdir -p '${deployDir}'"

echo '==> [${host}] scp archive -> ${deployDir}'
scp -P "${deployPort}" \
  -i "\$SSH_KEY_FILE" \
  -o StrictHostKeyChecking=accept-new \
  -o ConnectTimeout=8 \
  "${deploySrc}" "${deployUser}@${host}:${deployDir}/"

echo '==> [${host}] install + restart service'
ssh -p "${deployPort}" \
  -i "\$SSH_KEY_FILE" \
  -o StrictHostKeyChecking=accept-new \
  -o ConnectTimeout=8 \
  -o ServerAliveInterval=10 \
  -o ServerAliveCountMax=2 \
  "${deployUser}@${host}" "DEPLOY_DIR='${deployDir}' ARTIFACT_TAR='${env.ARCHIVE_NAME}' REMOTE_SERVICE='${remoteService}' USE_SUDO='${params.USE_SUDO}' bash -s" <<'EOF'
set -euo pipefail
cd "$DEPLOY_DIR"
tar -xzf "$ARTIFACT_TAR"
RELEASE_DIR="$(tar -tzf "$ARTIFACT_TAR" | cut -d/ -f1 | sed -n '1p')"
if [ -z "$RELEASE_DIR" ]; then
  echo 'failed to detect release dir from tarball'
  exit 1
fi
cd "$RELEASE_DIR"

if [ "$USE_SUDO" = "true" ]; then
  SUDO_CMD='sudo'
else
  SUDO_CMD=''
fi

$SUDO_CMD make install CONFIG_SRC=config.yaml
$SUDO_CMD systemctl restart "$REMOTE_SERVICE"
$SUDO_CMD systemctl is-active --quiet "$REMOTE_SERVICE"
EOF

echo '==> [${host}] done'
"""
              }
            }

            parallel fanout
          }
        }
      }
    }

    stage('Upload to JFrog') {
      when {
        expression { params.ACTION == 'Release' }
      }
      steps {
        script {
          if (!(env.ARCHIVE_NAME ?: '').trim()) {
            error('ARCHIVE_NAME is empty')
          }
          if (!(env.ARCHIVE_SRC ?: '').trim()) {
            error('ARCHIVE_SRC is empty')
          }

          sh """
            set -euo pipefail
            test -f "${env.ARCHIVE_SRC}"

            echo '=== upload archive ==='
            ls -al "${env.ARCHIVE_SRC}"
            du -h "${env.ARCHIVE_SRC}"

            curl --fail --show-error --silent \
              -u "${env.JFROG_USER}:${env.JFROG_PASS}" \
              --upload-file "${env.ARCHIVE_SRC}" \
              "${env.JFROG_REPO_URL}/${env.ARCHIVE_NAME}"
          """

          echo "Uploaded to JFrog: ${env.JFROG_REPO_URL}/${env.ARCHIVE_NAME}"
        }
      }
    }
  }

  post {
    success {
      echo "Pipeline success! mode=${params.ACTION}, artifact=${env.ARTIFACT_NAME ?: env.ARCHIVE_NAME ?: 'N/A'}"
    }
    failure {
      echo 'Pipeline failed, please check logs.'
    }
  }
}
