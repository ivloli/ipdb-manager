pipeline {
  agent any

  options {
    buildDiscarder(logRotator(numToKeepStr: '15'))
    disableConcurrentBuilds()
    timestamps()
  }

  parameters {
    choice(name: 'ACTION', choices: ['Release', 'Rollback'], description: 'Deploy mode： Release发版，Rollback 回滚')

    gitParameter(
      name: 'GIT_REF',
      type: 'PT_BRANCH_TAG',
      defaultValue: 'main',
      branchFilter: 'origin/(.*)',
      sortMode: 'DESCENDING_SMART',
      selectedValue: 'DEFAULT',
      useRepository: 'git@gitlab.gainetics.io:backend-cdn/dns-prj/ipdb_manager.git',
      quickFilterEnabled: true
    )

    extendedChoice(
      name: 'TARGET_IP',
      description: '选择部署的节点IP（可多选，支持 ip 或 ip:port）',
      type: 'PT_MULTI_SELECT',
      value: '10.0.5.238',
      defaultValue: '10.0.5.238',
      multiSelectDelimiter: ',',
      visibleItemCount: 5
    )

    text(
      name: 'CONFIG_YAML',
      defaultValue: '',
      description: '仅 Release 使用：会写入离线包里的 config.yaml 内容'
    )

    string(
      name: 'ROLLBACK_ARTIFACT',
      defaultValue: '',
      description: '仅 Rollback 使用，例如 ipdb-manager-offline-linux-amd64-v3.tar.gz'
    )

    string(name: 'TARGET_OS', defaultValue: 'linux', description: 'release package target OS')
    string(name: 'TARGET_ARCH', defaultValue: 'amd64', description: 'release package target ARCH')
    string(name: 'RELEASE_TAG', defaultValue: '', description: '可选，空则自动生成')
    booleanParam(name: 'USE_SUDO', defaultValue: true, description: '目标机安装与重启是否使用 sudo')
  }

  environment {
    APP_NAME = "${env.APP_NAME ?: 'ipdb-manager'}"

    GIT_CREDENTIALS_ID = 'deploy_01'
    REPOSITORY_URL     = 'git@gitlab.gainetics.io:backend-cdn/dns-prj/ipdb_manager.git'

    PATH = "/usr/local/go/bin:${env.PATH}"

    SSH_CRED_ID = 'ipdb-manager-ssh'
    DEPLOY_USER = "${env.DEPLOY_USER ?: 'root'}"
    REMOTE_SERVICE = "${env.REMOTE_SERVICE ?: 'ipdb-manager'}"
    REMOTE_DEPLOY_DIR = "${env.REMOTE_DEPLOY_DIR ?: '/opt/ipdb-manager/releases'}"

    JFROG_REPO_URL = 'https://artifactory.gainetics.io/artifactory/observe-dnps/prod-ipdb-xdb-manager'
    JFROG_USER     = 'dnps'
    JFROG_PASS     = 'SXKvkwRICe743VPhTkKIbA=='
  }

  stages {
    stage('Validate Parameters') {
      steps {
        script {
          def action = (params.ACTION ?: '').trim()
          if (!(action in ['Release', 'Rollback'])) {
            error('ACTION must be Release or Rollback')
          }

          if (action == 'Release') {
            def ref = (params.GIT_REF ?: '').trim()
            if (!ref) {
              error('GIT_REF is empty in Release mode')
            }
            def cfg = (params.CONFIG_YAML ?: '').trim()
            if (!cfg) {
              error('CONFIG_YAML is empty in Release mode')
            }
            echo 'Mode: Release'
            echo "GIT_REF: ${ref}"
          }

          if (action == 'Rollback') {
            def artifact = (params.ROLLBACK_ARTIFACT ?: '').trim()
            if (!artifact || artifact in ['-- only used when ACTION=Rollback --', 'NO_ARTIFACT_FOUND', 'ERROR_FETCHING_ARTIFACTS', 'ERROR']) {
              error("ROLLBACK_ARTIFACT is invalid in Rollback mode: ${artifact}")
            }

            def appNamePattern = java.util.regex.Pattern.quote(env.APP_NAME)
            def artifactPattern = ~/^${appNamePattern}-offline-linux-amd64-.+\.tar\.gz$/
            if (!(artifact ==~ artifactPattern)) {
              error("ROLLBACK_ARTIFACT format invalid: ${artifact}")
            }

            echo 'Mode: Rollback'
            echo "ROLLBACK_ARTIFACT: ${artifact}"
          }

          def targetIps = (params.TARGET_IP ?: '').trim()
          if (!targetIps) {
            error('TARGET_IP 不能为空，请选择至少一个部署节点IP')
          }
        }
      }
    }

    stage('Clean Workspace') {
      steps {
        deleteDir()
      }
    }

    stage('Checkout') {
      steps {
        script {
          def ref = (params.GIT_REF ?: 'main').toString().trim()
          if (!ref) {
            error('GIT_REF is empty')
          }

          def repoUrl = env.REPOSITORY_URL?.trim()
          def credId = env.GIT_CREDENTIALS_ID?.trim()

          if (!repoUrl) {
            error('REPOSITORY_URL is empty')
          }
          if (!credId) {
            error('GIT_CREDENTIALS_ID is empty')
          }

          echo "GIT_REF=${ref}"
          echo "REPOSITORY_URL=${repoUrl}"
          echo "GIT_CREDENTIALS_ID=${credId}"

          def isTag = false

          withCredentials([sshUserPrivateKey(
            credentialsId: credId,
            keyFileVariable: 'GIT_SSH_KEY',
            usernameVariable: 'GIT_SSH_USER'
          )]) {
            isTag = (sh(
              script: """#!/usr/bin/env bash
set +e
export GIT_SSH_COMMAND=\"ssh -i '$GIT_SSH_KEY' -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null\"
git ls-remote --tags '${repoUrl}' 'refs/tags/${ref}' | grep -q .
""",
              returnStatus: true
            ) == 0)
          }

          def refName = isTag ? "refs/tags/${ref}" : "refs/heads/${ref}"
          echo "Selected ${isTag ? 'TAG' : 'BRANCH'}: ${refName}"

          checkout([
            $class: 'GitSCM',
            branches: [[name: refName]],
            userRemoteConfigs: [[
              url: repoUrl,
              credentialsId: credId,
              refspec: '+refs/heads/*:refs/remotes/origin/* +refs/tags/*:refs/tags/*'
            ]],
            extensions: [
              [$class: 'CloneOption', shallow: false, noTags: false, timeout: 20],
              [$class: 'CleanBeforeCheckout']
            ]
          ])

          sh '''#!/usr/bin/env bash
set -euo pipefail
git submodule update --init --recursive
git rev-parse --short HEAD
git log -1 --oneline
'''
        }
      }
    }

    stage('Prepare Artifact') {
      when {
        expression { params.ACTION == 'Release' }
      }
      steps {
        script {
          env.GIT_COMMIT_SHORT = sh(script: 'git rev-parse --short=8 HEAD', returnStdout: true).trim()
          env.BUILD_TS = sh(script: 'date +%Y%m%d%H%M%S', returnStdout: true).trim()
          env.RELEASE_TAG_EFFECTIVE = (params.RELEASE_TAG ?: '').trim() ?: "${env.GIT_COMMIT_SHORT}-${env.BUILD_TS}"

          env.CONFIG_SRC = "${env.WORKSPACE}/jenkins-config.yaml"
          writeFile file: env.CONFIG_SRC, text: params.CONFIG_YAML

          env.ARCHIVE_NAME = "${env.APP_NAME}-offline-${params.TARGET_OS}-${params.TARGET_ARCH}-${env.RELEASE_TAG_EFFECTIVE}.tar.gz"
          env.ARCHIVE_SRC = "${env.WORKSPACE}/${env.ARCHIVE_NAME}"
          env.ARTIFACT_NAME = env.ARCHIVE_NAME

          sh """
            set -e
            test -s "${env.CONFIG_SRC}"

            make release-package \
              TARGET_OS='${params.TARGET_OS}' \
              TARGET_ARCH='${params.TARGET_ARCH}' \
              RELEASE_TAG='${env.RELEASE_TAG_EFFECTIVE}' \
              CONFIG_SRC='${env.CONFIG_SRC}'

            test -f "${env.ARCHIVE_SRC}"
            ls -al "${env.ARCHIVE_SRC}"
            du -h "${env.ARCHIVE_SRC}"
          """

          echo "Prepared release archive: ${env.ARCHIVE_NAME}"
        }
      }
    }

    stage('Download Artifact') {
      when {
        expression { params.ACTION == 'Rollback' }
      }
      steps {
        script {
          env.ARTIFACT_NAME = (params.ROLLBACK_ARTIFACT ?: '').trim()
          env.ARCHIVE_NAME = env.ARTIFACT_NAME
          env.ARCHIVE_SRC = "${env.WORKSPACE}/${env.ARCHIVE_NAME}"

          sh """
            set -e
            curl --fail --show-error --silent \
              -u "${env.JFROG_USER}:${env.JFROG_PASS}" \
              -o "${env.ARCHIVE_SRC}" \
              "${env.JFROG_REPO_URL}/${env.ARCHIVE_NAME}"

            ls -al "${env.ARCHIVE_SRC}"
            du -h "${env.ARCHIVE_SRC}"
          """

          echo "Downloaded rollback archive: ${env.ARCHIVE_NAME}"
        }
      }
    }

    stage('Deploy to Targets') {
      steps {
        script {
          def deploySrc = (env.ARCHIVE_SRC ?: '').trim()
          if (!deploySrc) {
            error('ARCHIVE_SRC is empty')
          }

          sh """
            set -e
            test -f "${deploySrc}"
            ls -al "${deploySrc}"
          """

          def hosts = (params.TARGET_IP ?: '').trim()
            .replace(',', ' ')
            .split(/\s+/)
            .findAll { it }

          if (hosts.isEmpty()) {
            error('TARGET_IP env is empty')
          }

          def deployDir = (env.REMOTE_DEPLOY_DIR ?: '/opt/ipdb-manager/releases').trim()
          def deployUser = (env.DEPLOY_USER ?: 'root').trim()
          def remoteService = (env.REMOTE_SERVICE ?: 'ipdb-manager').trim()

          echo "Deploy artifact : ${env.ARCHIVE_NAME}"
          echo "Source archive  : ${deploySrc}"
          echo "Deploy targets (${hosts.size()}): ${hosts.join(', ')}"
          echo "DEPLOY_USER=${deployUser}"
          echo "REMOTE_DEPLOY_DIR=${deployDir}"
          echo "REMOTE_SERVICE=${remoteService}"

          withCredentials([sshUserPrivateKey(
            credentialsId: env.SSH_CRED_ID,
            keyFileVariable: 'SSH_KEY_FILE'
          )]) {
            def fanout = [:]

            for (int i = 0; i < hosts.size(); i++) {
              def hostFull = hosts[i]

              fanout["deploy_${hostFull}"] = {
                def parts = hostFull.split(':')
                def host = parts[0]
                def port = parts.size() > 1 ? parts[1] : '22'

                sh """#!/usr/bin/env bash
set -euo pipefail

SSH_OPTS="-i \$SSH_KEY_FILE -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o ConnectTimeout=8 -p ${port}"
SCP_OPTS="-i \$SSH_KEY_FILE -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -P ${port}"

echo "==> [${host}] ensure dir: ${deployDir}"
ssh \$SSH_OPTS ${deployUser}@${host} "mkdir -p '${deployDir}'"

echo "==> [${host}] scp archive -> ${deployDir}"
scp \$SCP_OPTS "${deploySrc}" ${deployUser}@${host}:${deployDir}/

                echo "==> [${host}] extract + install + restart"
                ssh \$SSH_OPTS ${deployUser}@${host} "set -e
  if [ '${params.USE_SUDO}' = 'true' ]; then
    SUDO_CMD='sudo'
  else
    SUDO_CMD=''
  fi
  cd '${deployDir}'
  tar -xzf '${env.ARCHIVE_NAME}'
  RELEASE_DIR=\$(tar -tzf '${env.ARCHIVE_NAME}' | cut -d/ -f1 | sed -n '1p')
  test -n \"\$RELEASE_DIR\"
  cd \"\$RELEASE_DIR\"
  \$SUDO_CMD make install CONFIG_SRC=config.yaml
  \$SUDO_CMD systemctl daemon-reload
  \$SUDO_CMD systemctl restart '${remoteService}'
  \$SUDO_CMD systemctl is-active --quiet '${remoteService}'
"

echo "==> [${host}] done"
"""
              }
            }

            parallel fanout
          }
        }
      }
    }

    stage('Upload to JFrog') {
      when {
        expression { params.ACTION == 'Release' }
      }
      steps {
        script {
          if (!(env.ARCHIVE_NAME ?: '').trim()) {
            error('ARCHIVE_NAME is empty')
          }
          if (!(env.ARCHIVE_SRC ?: '').trim()) {
            error('ARCHIVE_SRC is empty')
          }

          sh """
            set -e
            test -f "${env.ARCHIVE_SRC}"

            curl --fail --show-error --silent \
              -u "${env.JFROG_USER}:${env.JFROG_PASS}" \
              --upload-file "${env.ARCHIVE_SRC}" \
              "${env.JFROG_REPO_URL}/${env.ARCHIVE_NAME}"
          """

          echo "Uploaded to JFrog: ${env.JFROG_REPO_URL}/${env.ARCHIVE_NAME}"
        }
      }
    }
  }

  post {
    success {
      echo "Pipeline success! mode=${params.ACTION}, artifact=${env.ARTIFACT_NAME ?: env.ARCHIVE_NAME ?: 'N/A'}"
    }
    failure {
      echo 'Pipeline failed, please check logs.'
    }
  }
}
